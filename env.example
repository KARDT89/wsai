# ─── Database ────────────────────────────────────────────────────────────────
# PostgreSQL connection string.
# Local dev default matches docker-compose.yml (port 5433).
DATABASE_URL=postgresql://postgres:password@localhost:5433/wsai

# ─── Auth ────────────────────────────────────────────────────────────────────
# Random secret used to sign sessions. Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=

# Base URL of the app — used for OAuth redirects and email links.
BETTER_AUTH_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Google OAuth credentials (used for both user login and Gmail/Calendar access).
# Create at: https://console.cloud.google.com/apis/credentials
BETTER_AUTH_GOOGLE_CLIENT_ID=
BETTER_AUTH_GOOGLE_CLIENT_SECRET=

# ─── Corsair ──────────────────────────────────────────────────────────────────
# Key-encryption key for Corsair's credential storage.
# Can be the same value as BETTER_AUTH_SECRET, or a separate 32+ char secret.
CORSAIR_KEK=

# Override the base URL Corsair uses when registering webhooks and OAuth redirect
# URIs. Required in local dev when your machine isn't publicly reachable.
# Use ngrok: https://ngrok.com — set this to your ngrok HTTPS URL.
# CORSAIR_WEBHOOK_URL=https://your-subdomain.ngrok.io

# ─── AI agent ────────────────────────────────────────────────────────────────
# Default model provider when a user hasn't set their own API key.
# Get a key at: https://openrouter.ai
OPENROUTER_API_KEY=

# ─── Inngest (production only) ───────────────────────────────────────────────
# Not needed for local development (Inngest dev server runs without keys).
# Set these when deploying to production.
# INNGEST_SIGNING_KEY=
# INNGEST_EVENT_KEY=
